# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: openai | anthropic | bedrock | gemini | ollama
LITMDX_AGENT_PROVIDER=openai

# Provider-specific API keys (only the one you use is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Generic override — takes priority over the provider-specific vars above
# LITMDX_AGENT_API_KEY=

# ── Model ─────────────────────────────────────────────────────────────────────
# Leave unset to use the provider default
# LITMDX_AGENT_MODEL=gpt-4o

# ── Docs index ───────────────────────────────────────────────────────────────
# Local docs directory (default: ./docs)
# LITMDX_AGENT_DOCS_DIR=./docs

# Remote pre-built index — takes priority over LITMDX_AGENT_DOCS_DIR
# LITMDX_AGENT_DOCS_INDEX_URL=https://my-docs.example.com/docs-index.json

# ── Server ───────────────────────────────────────────────────────────────────
# LITMDX_AGENT_PORT=8000
# LITMDX_AGENT_TITLE=My Project

# ── Session storage (Node.js / Lambda) ───────────────────────────────────────
# FileStorage directory (default: OS tmpdir + /litmdx-sessions)
# LITMDX_AGENT_SESSIONS_DIR=/tmp/my-sessions

# S3Storage — takes priority over LITMDX_AGENT_SESSIONS_DIR when set
# LITMDX_AGENT_S3_BUCKET=my-sessions-bucket
# LITMDX_AGENT_S3_REGION=us-east-1   # falls back to AWS_REGION
# LITMDX_AGENT_S3_PREFIX=sessions/

# ── MCP clients ───────────────────────────────────────────────────────────────
# Enable Context7 MCP client for live library documentation lookup.
# Context7 exposes `resolve-library-id` and `get-library-docs` tools so the
# agent can answer "how do I use <library>?" questions from up-to-date docs.
# LITMDX_AGENT_CONTEXT7=false

# ── Vended tools ──────────────────────────────────────────────────────────────
# Enable the notebook vended tool from @strands-agents/sdk.
# Gives the agent a persistent scratchpad to plan multi-step tasks and track
# progress across invocations. State persists automatically with the session.
# Works in all environments: Node.js, browsers, Cloudflare Workers.
# LITMDX_AGENT_NOTEBOOK=false

# ── AWS credentials (for Bedrock or S3Storage) ────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── Cloudflare Workers ────────────────────────────────────────────────────────
# CF Workers don't use process.env — pass bindings via wrangler.toml instead.
# KV/R2 storage and env vars are injected as the `env` object in the handler:
#
#   export default {
#     fetch(req, env) {
#       return createHonoApp({
#         provider: 'openai',
#         apiKey: env.OPENAI_API_KEY,        // wrangler.toml [vars]
#         storage: new KVStorage(env.SESSIONS_KV),  // [[kv_namespaces]]
#       }).fetch(req, env);
#     },
#   };
